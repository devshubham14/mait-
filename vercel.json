{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_SSR": "true"
  },
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/:path((?!_next/static|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
